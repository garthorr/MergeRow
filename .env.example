# Copy this file to .env and fill in your real values.
# .env is git-ignored so these stay out of version control.

# Baserow instance the app proxies /api/ to. Examples:
#   https://api.baserow.io                 (Baserow Cloud)
#   https://baserow.example.com            (self-hosted, public hostname)
#   http://baserow:80                      (self-hosted, internal Docker service name)
BASEROW_URL=https://baserow.example.com
